{
  "name": "@meetjamie/obsidian-sync",
  "version": "0.1.0",
  "description": "Sync your Jamie meeting notes and transcripts into Obsidian.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check",
    "format": "biome check --write",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^20.12.12",
    "esbuild": "^0.21.5",
    "obsidian": "^1.4.11",
    "typescript": "^5.4.5",
    "vitest": "^3.0.0"
  }
}
